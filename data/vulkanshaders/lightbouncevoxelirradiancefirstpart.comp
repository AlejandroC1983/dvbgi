/////////////////////////////////////////////////////////////////////////////////////////////

/** Integer version o fthe dot product of two 3 component vectors
* @param a [in] one of the two vectors
* @param b [in] one of the two vectors
* @return rsult of the dot product between both vectors */
int integerDot(ivec3 a, ivec3 b)
{
	return a.x * b.x + a.y * b.y + a.z * b.z;
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** hashed value for texture coordinates given as parameter in a voxelization of size given as parameter
* @param texcoord  [in] texture coordinates
* @param voxelSize [in] voxelization size
* @return hashed value */
int getHashedIndex(ivec3 texcoord)
{
	return texcoord.x * g_voxelSizeInt * g_voxelSizeInt + texcoord.y * g_voxelSizeInt + texcoord.z;
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Returns from voxelOccupied if the current voxel is occupied by at least one fragment, or false otherwise
* @param indexHashed [in] hashed texture coordinates to test
* @return true if voxel occupied, false otherwise */
bool isVoxelOccupied(uint indexHashed)
{    
	float integerPart;
	float indexDecimalFloat = float(indexHashed) / 32.0;
	float fractional        = modf(indexDecimalFloat, integerPart);
	uint index              = uint(integerPart);
	uint bit                = uint(fractional * 32.0);
	bool result             = ((voxelOccupied[index] & (1 << bit)) > 0);
	return result;
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Returns from voxelOccupiedDynamic if the current voxel is occupied by one voxel, or false otherwise
* @param indexHashed [in] hashed texture coordinates to test
* @return true if voxel occupied, false otherwise */
bool isVoxelOccupiedDynamic(uint indexHashed)
{
	float integerPart;
	float indexDecimalFloat = float(indexHashed) / 32.0;
	float fractional        = modf(indexDecimalFloat, integerPart);
	uint index              = uint(integerPart);
	uint bit                = uint(fractional * 32.0);
	bool result             = ((voxelOccupiedDynamic[index] & (1 << bit)) > 0);
	return result;
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Computes the unhashed 3D coordinates for the position given with hashed value as parameter, for a uniform
* voxelization volume given by voxelizationWidth
* @param value [in] value to unhash
* @return unhashed value for parameter value */
ivec3 unhashValue(uint value)
{
	float number     = float(value) / g_voxelSize;

	ivec3 result;
	float integerPart;
	float fractional = modf(number, integerPart);
	result.z         = int(fractional * g_voxelSize);
	number          /= g_voxelSize;
	fractional       = modf(number, integerPart);
	result.y         = int(fractional * g_voxelSize);
	result.x         = int(integerPart);

	return result;
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Computes texture space coordinates of the world coordinates given as parameter
* @param worldCoordinates [in] world coordinates
* @return texture space coordinates of the world coordinates given as parameter */
ivec3 worldToVoxelSpaceInteger(vec3 worldCoordinates)
{
	vec3 result = worldCoordinates;
	result     -= g_sceneMin;
	result     /= g_sceneExtent;
	result     *= vec3(g_voxelSize);

	return ivec3(int(result.x), int(result.y), int(result.z));
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Computes world space coordinates for 3D texture coordinates
* @param coordinates [in] texture coordinates
* @return world coordinates of the voxel coordinates given as parameter */
vec3 voxelSpaceToWorld(ivec3 coordinates)
{
	vec3 result = vec3(float(coordinates.x), float(coordinates.y), float(coordinates.z));
	result     /= vec3(g_voxelSize);
	result     *= g_sceneExtent;
	result     += g_sceneMin;
	result     += (g_sceneExtent / g_voxelSize) * 0.5;
	return result;
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Search in voxelHashedPositionCompactedBuffer for the index of the hashed value
* of the texcoord parameter.
* @param texcoord [in] 3D texture coordinates to find index for
* @return uvec2 with index in .x field and test result in .y field */
uvec2 findHashedCompactedPositionIndex(uvec3 texcoord)
{
	uint index = texelFetch(staticVoxelIndexTexture, ivec3(texcoord), 0).r;

	if(index != UINT_MAX_VALUE)
	{
		return uvec2(index, 1);
	}

	return uvec2(0, 0);
}

////////////////////////////////////////////////////////////////////////////////////////////////////////

/** Test whether the voxel at index indexHashed has any face set as lit
* @param indexHashed [in] voxel index to test if it has any voxel face as lit
* @return true if any voxel face as been set as lit, false otherwise */
bool isVoxelLit(uint indexHashed)
{
	return (litTestVoxelPerByte[indexHashed] > 0);
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Returns the form factor from a differential area with normal normalDA and to a
* differential area with position positionDB and normal normalDB
* NOTE: taken from J. R. Wallace, K. A. Elmquist, and E. A. Haines. 1989. A Ray tracing algorithm for progressive radiosity
* @param normalDA             [in] Normal of the differential area A
* @param positionDA           [in] Point position of the differential area A
* @param normalDB             [in] Normal of the differential area B
* @param positionDB           [in] Point position of the differential area B
* @param isDynamic            [in] flag to know if the computation being done has a dynamic voxel involved
* @param isImmediateNeighbour [in] flag to know if the differential area computation has an immediate neighbour voxel involved
* @return form factor value */
float differentialAreaFormFactor(vec3 normalDA, vec3 positionDA, vec3 normalDB, vec3 positionDB, bool isDynamic, bool isImmediateNeighbour)
{
	vec3 dAtoDiskDirection = positionDB - positionDA;
	float distanceSq       = dot(dAtoDiskDirection, dAtoDiskDirection);
	dAtoDiskDirection      = normalize(dAtoDiskDirection);
	float cosTheta1        = dot(normalDA, dAtoDiskDirection);
	cosTheta1              = clamp(cosTheta1, 0.0, 1.0);
	float cosTheta2        = dot(normalDB, -1.0 * dAtoDiskDirection);
	cosTheta2              = clamp(cosTheta2, 0.0, 1.0);

	// To avoid close points reach too high values due to the form factor formula
	if(isImmediateNeighbour || isDynamic)
	{
		distanceSq = max(distanceSq, 0.05);
	}
	else
	{
		distanceSq = max(distanceSq, float(MIN_SQUARED_DISTANCE_FORM_FACTOR_STATIC) / 10.0);
	}
	
	float nSamples = 0.0;

#ifdef ADD_EXTRA_VALUE_FORM_FACTOR
	float distanceAttenuationStart = 15.0;
	float distanceBetweenPoints    = distance(positionDA, positionDB);
	distanceBetweenPoints = clamp(distanceBetweenPoints, 0.0, distanceAttenuationStart);

	if(!isDynamic)
	{
		nSamples = 100.0 * (1.0 - (distanceBetweenPoints / distanceAttenuationStart)) * (1.0 - (distanceBetweenPoints / distanceAttenuationStart));
	}
#endif // ADD_EXTRA_VALUE_FORM_FACTOR

	return (cosTheta1 * cosTheta2) / (PI * distanceSq + nSamples);
}

/////////////////////////////////////////////////////////////////////////////////////////////

vec4 convRGBA8ToVec4New(uint val)
{
	return vec4(float((val&0x000000FF)), float((val&0x0000FF00)>>8U), float ((val&0x00FF0000)>>16U), float((val&0xFF000000)>>24U));
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Test whether the voxel next to the one given by the test coordinates in the direction test -> destination is occupied
* @param origin      [in] voxel to test
* @param destination [in] voxel destination coordinates
* @return true is occupied, false otherwise */
bool isVoxelNeighBourOccupied(ivec3 test, ivec3 destination)
{
	ivec3 offsetDirection = destination - test;

	// Return true for cases where test and destination parameters only differ in 1 unit
	if(max(abs(offsetDirection.x), max(abs(offsetDirection.y), abs(offsetDirection.z))) <= 1)
	{
		return false;
	}

	vec3 directionFloat = vec3(offsetDirection);
	directionFloat      = normalize(directionFloat);
	offsetDirection     = ivec3(round(directionFloat.x), round(directionFloat.y), round(directionFloat.z));

	uint testValue            = getHashedIndex(test + offsetDirection);
	bool voxelOccupied        = isVoxelOccupied(testValue);
	bool voxelOccupiedDynamic = isVoxelOccupiedDynamic(testValue);

	return voxelOccupied || voxelOccupiedDynamic;
}

/////////////////////////////////////////////////////////////////////////////////////////////

vec3 offsetVoxelCoordinates(vec3 sufraceHitNormal, vec3 voxelCenter)
{
    vec3 projectedSurfaceHitNormal;

    switch (g_axisIndex)
    {
        case 0: case 1:
        {
            projectedSurfaceHitNormal = vec3(0.0, sufraceHitNormal.y, sufraceHitNormal.z); // YZ plane projection
            break;
        }
        case 2: case 3:
        {
            projectedSurfaceHitNormal = vec3(sufraceHitNormal.x, 0.0, sufraceHitNormal.z); // XZ plane projection
            break;
        }
        case 4: case 5:
        {
            projectedSurfaceHitNormal = vec3(sufraceHitNormal.x, sufraceHitNormal.y, 0.0); // XY plane projection
            break;
        }
    }

    if (length(projectedSurfaceHitNormal) == 0.0)
    {
        return voxelCenter;
    }

    projectedSurfaceHitNormal = normalize(projectedSurfaceHitNormal);

    return voxelCenter + projectedSurfaceHitNormal * g_voxelWorldHalfDiagonal;
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Compute the reflected irradiance from a directional emitter with direction lightDirection (from the surface being analysed)
* for a lambertian surface with normal direction surfaceNormal
* https://bheisler.github.io/post/writing-raytracer-in-rust-part-2/
* https://www.scratchapixel.com/lessons/3d-basic-rendering/introduction-to-shading/diffuse-lambertian-shading.html
* @param lightDirection  [in] direction towards the light
* @param surfaceNormal   [in] normal direction of the surface being analysed
* @param emitterRadiance [in] emitter radiance
* @return form factor value */
float reflectedIrradianceDirectionalLight(vec3 lightDirection, vec3 surfaceNormal, float emitterRadiance)
{
    float reflectedIrradiance = dot(lightDirection, surfaceNormal);
    reflectedIrradiance      *= emitterRadiance;
    reflectedIrradiance      /= PI;
    
    return reflectedIrradiance;
}

/////////////////////////////////////////////////////////////////////////////////////////////

/** Compute irradiance from a voxel with coordinates tempCoordinates0, normal surfaceNormal
* towards the voxel g_voxelTextureCoordinates being analysed
* @param hitWorldCoordinates   [in] world coordinates of the hit point
* @param hitTextureCoordinates [in] voxel coordinates of the hit point
* @param surfaceNormal         [in] normal direction for the surface associated to the voxel
* @param directlyVisible       [in] for those case where the visibility is known, avoid the "isVoxelNeighBourOccupied" test
* @param isDynamicVoxel        [in] in case the irradiance is from a dynamic voxel
* @param isImmediateNeighbour  [in] flag to know if the differential area computation has an immediate neighbour voxel involved
* @return irradiance between point at worldCoordinates with normal surfaceNormal and  */
vec4 voxelToVoxelIrradianceBasic(vec3 hitWorldCoordinates, ivec3 hitTextureCoordinates, vec3 surfaceNormal, bool directlyVisible, bool isDynamicVoxel, bool isImmediateNeighbour)
{
	if(!directlyVisible && isVoxelNeighBourOccupied(hitTextureCoordinates, g_voxelTextureCoordinates))
	{
		return vec4(0.0, 0.0, 0.0, 1.0);
	}

	vec3 emitterNormal                     = myMaterialData.lightForwardEmitterRadiance.xyz;
	vec3 emitterPosition                   = myMaterialData.lightPosition.xyz;
	float emitterRadiance                  = myMaterialData.lightForwardEmitterRadiance.w;

	// Offset the voxel position from where the irradiance is being computed
	vec3 voxelWorldCoordinatesOffset       = offsetVoxelCoordinates(surfaceNormal.xyz, g_voxelWorldCoordinates);

	// Offset the surface hit in theopposite direction of the surface normal (currently, the two voxel positions in worl coordinates would be taken into consideration)
	vec3 voxelRayHitWorldCoordinatesOffset = offsetVoxelCoordinates(-1.0 * surfaceNormal.xyz, hitWorldCoordinates);

	vec3 g_voxelNormal                     = vec3(arrayVoxelRayDirection[g_axisIndex]);

	float reflectedIrradiance              = reflectedIrradianceDirectionalLight(normalize(emitterPosition), surfaceNormal, emitterRadiance);
	float formFactorVoxel0                 = differentialAreaFormFactor(g_voxelNormal, voxelWorldCoordinatesOffset, surfaceNormal.xyz, voxelRayHitWorldCoordinatesOffset, isDynamicVoxel, isImmediateNeighbour);

	float cosAngleSurfaceNormalEmitterDirection = dot(surfaceNormal, normalize(emitterPosition - hitWorldCoordinates));

	if(cosAngleSurfaceNormalEmitterDirection < -0.1)
	{
		return vec4(0.0, 0.0, 0.0, 1.0);
	}

	vec3 voxelReflectance;
	uint voxelReflectanceUint;
	if(isDynamicVoxel)
	{
		voxelReflectanceUint = imageLoad(dynamicVoxelizationReflectanceTexture, hitTextureCoordinates).r;
    	voxelReflectance     = convRGBA8ToVec4New(voxelReflectanceUint).xyz;
	}
	else
	{
		voxelReflectanceUint = imageLoad(voxelizationReflectance, hitTextureCoordinates).r;
    	voxelReflectance     = convRGBA8ToVec4New(voxelReflectanceUint).xyz;
	}

	// In some cases, the normal direction from the hit point from the voxel face ,surfaceNormal, is nor representative of the majority of the gometry being intersected, with normal
	// directions that vary a lot from one voxel to another. Takking the maximum value of the forma factor betwen the normal direction data and a computed surface normal midway between
	// the directions from the sample to the emitter and from the sample to the voxel whose irradiance per face is being computed is a try to minimize that variation of sampled surface normals.
	vec3 currentIrradiance          = reflectedIrradiance * formFactorVoxel0 * emitterRadiance * voxelReflectance;
	float irradianceVectorLength    = length(currentIrradiance);
	float maxIrradiancevectorLength = isDynamicVoxel ? float(MAX_IRRADIANCE_DYNAMIC_TO_STATIC_VECTOR_LENGTH) / 100.0 : isImmediateNeighbour ? 1000000.0 : float(MAX_IRRADIANCE_STATIC_TO_STATIC_VECTOR_LENGTH) / 100.0;
	
	if(irradianceVectorLength > maxIrradiancevectorLength)
	{
		currentIrradiance /= irradianceVectorLength;
		currentIrradiance *= maxIrradiancevectorLength;
	}

	if(dot(currentIrradiance.xyz, vec3(1.0)) > MIN_IRRADIANCE_VALUE)
    {

    	return vec4(currentIrradiance.xyz, 1.0);
    }

	return vec4(0.0, 0.0, 0.0, 1.0);
}


vec4 computeIrradianceStaticVoxel(uint directionIndex, uint offsetIndex)
{
	vec4 accumulatedIrradiance  = vec4(0.0, 0.0, 0.0, 1.0);
	uint valueToDecode          = uint(voxelVisibility4Bytes[offsetIndex + directionIndex]);
    vec4 decodedNormalDistance  = decodeHitInformation(valueToDecode);

    if(valueToDecode != UINT_MAX_VALUE)
    {
        vec3 samplingDirection      = rayDirection[g_axisIndex * NUMBER_DESIRED_POINT + directionIndex].xyz;
        vec3 hitPositionStaticVoxel = g_rayOrigin + samplingDirection * decodedNormalDistance.w;
        ivec3 coordinates           = worldToVoxelSpaceInteger(hitPositionStaticVoxel);
        uint hashedIndex0           = uint(getHashedIndex(coordinates));
        vec3 hitSampleNormal        = decodedNormalDistance.xyz;        

        if(isVoxelLit(hashedIndex0)) // TODO: Enter here only if the proper voxel faces are lit
        {
            accumulatedIrradiance = voxelToVoxelIrradianceBasic(hitPositionStaticVoxel, coordinates, hitSampleNormal, true, false, false);

            if(record)
		    {
        		lightBounceVoxelDebug[counter++] = 3050.0;
        	}
        }
        else if(isVoxelOccupied(hashedIndex0))
        {
            // ADD HERE LOGIC IN CASE STATIC VOXEL SEES ENVIRONMENT, UINT_MAX_VALUE, COMPARE DATA WITH INITIAL DATA AND MAKE SURE IT MAKES SENSE
            // IMPORTANT: NOW THT THE REAL HIT POINTS ARE KNOWN FOR STATIC AND DYNAMIC VOXEL VISIBILITY, 
            // REPLACE AND SIMPLIFY COMPUTATIONS USING THOSE VALUES INSTEAD OF ROUNDED VOXEL COORDINATES
            float voxelSizeWorldSpace = g_sceneExtent.x / g_voxelSize;
            float thresholdDistance   = voxelSizeWorldSpace * float(THRESHOLD_DISTANCE_VOXEL_MULTIPLIER);
            accumulatedIrradiance     = irradianceFromAnyLitCloseNeighbourStatic(coordinates, hitSampleNormal, thresholdDistance);

            if(record)
		    {
        		lightBounceVoxelDebug[counter++] = 3075.0;
        	}
        }            
    }

    if(record)
    {
        lightBounceVoxelDebug[counter++] = 3100.0;
        lightBounceVoxelDebug[counter++] = float(accumulatedIrradiance.x);
        lightBounceVoxelDebug[counter++] = float(accumulatedIrradiance.y);
        lightBounceVoxelDebug[counter++] = float(accumulatedIrradiance.z);
        lightBounceVoxelDebug[counter++] = 3400.0;
    }

    return accumulatedIrradiance;
}

